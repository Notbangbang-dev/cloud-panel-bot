# ============================================================
#  Cloud Panel Bot — configuration
#  Copy to ".env" and fill in. Never commit your real .env!
# ============================================================

# ---- Discord (required) ----
# From https://discord.com/developers/applications -> Bot -> Token
DISCORD_TOKEN=your-bot-token-here
# Application (client) ID, from General Information
CLIENT_ID=your-application-id
# Optional: a server (guild) ID for INSTANT slash-command registration while
# developing. Leave blank to register commands globally (can take ~1 hour).
GUILD_ID=

# ---- Branding (optional) ----
BOT_BRAND_NAME=Cloud Panel
BOT_BRAND_TAGLINE=Deploy. Scale. Dominate.
# A logo/icon URL shown in embeds (defaults to the bot's avatar)
BOT_BRAND_ICON=
